# ============================================
# Project "25th July" — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================

# ── Database ──────────────────────────────────
DATABASE_URL="postgresql://twentyfifth:secret@localhost:5432/twentyfifth_july?schema=public"

# ── Redis ─────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── JWT Secrets ───────────────────────────────
JWT_ACCESS_SECRET="CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING"
JWT_REFRESH_SECRET="CHANGE_ME_TO_ANOTHER_RANDOM_64_CHAR_STRING"

# ── Email (Resend) ────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="noreply@developedbybasit.me"

# ── App ───────────────────────────────────────
APP_URL="https://25th-july.developedbybasit.me"
API_URL="https://25th-july.developedbybasit.me"
NODE_ENV="development"
PORT=3001

# ── WebAuthn ──────────────────────────────────
WEBAUTHN_RP_NAME="25th July"
WEBAUTHN_RP_ID="25th-july.developedbybasit.me"
WEBAUTHN_ORIGIN="https://25th-july.developedbybasit.me"

# ── Media Storage ─────────────────────────────
MEDIA_STORAGE_PATH="./data/media"
MEDIA_MAX_SIZE_MB=100
MEDIA_EXPIRY_DAYS=7

# ── Rate Limiting ─────────────────────────────
RATE_LIMIT_ENABLED=true
